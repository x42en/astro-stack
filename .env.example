# =============================================================================
# Astro-Stack — Environment Variables Example
# Copy to .env and edit before running docker compose up
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Astro-Stack
LOG_LEVEL=info                   # debug | info | warning | error

# ── Authentication (disabled by default) ──────────────────────────────────────
AUTH_ENABLED=false               # Set to 'true' to require JWT tokens
JWT_SECRET=change-me-in-production-min-16-chars
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=60

# ── Database ──────────────────────────────────────────────────────────────────
# Use your existing PostgreSQL instance
DATABASE_URL=postgresql+asyncpg://astro:astro@postgres:5432/astrostack

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ── Storage paths (host paths mapped into containers) ─────────────────────────
INBOX_HOST_PATH=./data/inbox        # Drop session folders here
SESSIONS_HOST_PATH=./data/sessions  # Intermediate processing files
OUTPUT_HOST_PATH=./data/output      # Final processed images
MODELS_HOST_PATH=./data/models      # AI model weight files (.pth)

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=8080

# ── Pipeline ──────────────────────────────────────────────────────────────────
PIPELINE_MAX_RETRIES=3
SESSION_STABILITY_DELAY=30.0        # Seconds before considering a session ready

# ── GPU ───────────────────────────────────────────────────────────────────────
# Worker GPU assignments are fixed per container in docker-compose.yml
# astro-worker-gpu0 → GPU 0 (CUDA_VISIBLE_DEVICES=0)
# astro-worker-gpu1 → GPU 1 (CUDA_VISIBLE_DEVICES=1)
GPU_DEVICES=0,1
