{
  "kind": "astrostack-profile",
  "schema_version": 1,
  "name": "Preset — Quality",
  "description": "Best-looking render with every safe option enabled. The pipeline auto-disables super-resolution on bright nebulae and star-separation on galaxies/clusters, and switches GraXpert from BGE to chained Object + Stars deconvolution on galaxies/clusters via the object-type catalogue.",
  "config": {
    "rejection_algorithm": "winsorized",
    "rejection_low": 3.0,
    "rejection_high": 3.0,
    "normalization": "addscale",
    "drizzle_enabled": true,
    "drizzle_scale": 2,
    "drizzle_pixfrac": 0.7,
    "debayer_pattern": "auto",
    "findstar_override_enabled": false,
    "findstar_radius": 10,
    "findstar_sigma": 1.0,
    "findstar_roundness": 0.5,
    "findstar_relax": false,
    "plate_solving_enabled": true,
    "plate_solving_radius_deg": 180.0,
    "plate_solving_speed": "auto",
    "gradient_removal_enabled": true,
    "gradient_removal_method": "ai",
    "gradient_removal_ai_model": "1.0.1",
    "gradient_removal_correction": "Subtraction",
    "gradient_removal_smoothing": 1.0,
    "gradient_removal_deconv_strength": 0.5,
    "gradient_removal_deconv_psfsize": 0.3,
    "gradient_removal_deconv_batch_size": 4,
    "stretch_method": "asinh",
    "stretch_strength": 180.0,
    "color_calibration_enabled": true,
    "camera_defiltered": true,
    "photometric_calibration_enabled": false,
    "denoise_enabled": true,
    "denoise_engine": "cosmic_clarity",
    "denoise_strength": 0.65,
    "denoise_luminance_only": true,
    "denoise_graxpert_ai_model": "3.0.2",
    "denoise_graxpert_batch_size": 4,
    "sharpen_enabled": true,
    "sharpen_stellar_amount": 0.45,
    "sharpen_nonstellar_amount": 0.55,
    "sharpen_radius": 2,
    "super_resolution_enabled": true,
    "super_resolution_scale": 2,
    "star_separation_enabled": true,
    "star_separation_recombine": true,
    "star_separation_nebula_weight": 0.8,
    "star_separation_star_weight": 0.5,
    "max_retries": 3
  }
}
